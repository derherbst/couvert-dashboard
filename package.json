{
  "name": "couvert-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,api -c blue,magenta \"npm:dev:next\" \"npm:dev:api\"",
    "dev:next": "next dev",
    "dev:api": "json-server --watch db.json --port 4000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "9.18.0",
    "eslint-config-next": "16.2.7",
    "json-server": "^0.17.4",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3"
  }
}
